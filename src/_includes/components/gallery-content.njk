<div class="row pt-2">
    <!-- Sidebar for Desktop Filters -->
    <aside class="col-lg-3 d-none d-lg-block sticky-top align-self-start" style="top: 100px;">
        <template x-if="config.sidebarGoose">
            <div class="text-center mb-4">
                <img :src="config.sidebarGoose" alt="Mascot" class="img-fluid mt-4">
            </div>
        </template>

        <div class="mb-4">
            <div class="segmented-control d-flex gap-1 p-1 bg-dark bg-opacity-10 rounded-pill">
                <a href="{{ "/pages/stalls.html" | url }}" class="btn btn-sm border-0 rounded-pill flex-fill py-2 fw-bold transition-200"
                   :class="currentKey === 'stalls' ? 'bg-white shadow text-primary' : 'text-light hover-dark-tiny'">Stalls</a>
                <a href="{{ "/pages/food.html" | url }}" class="btn btn-sm border-0 rounded-pill flex-fill py-2 fw-bold transition-200"
                   :class="currentKey === 'food' ? 'bg-white shadow text-primary' : 'text-light hover-dark-tiny'">Food</a>
                <a href="{{ "/entertainment.html" | url }}" class="btn btn-sm border-0 rounded-pill flex-fill py-2 fw-bold transition-200"
                   :class="currentKey === 'entertainment' ? 'bg-white shadow text-primary' : 'text-light hover-dark-tiny'">Events</a>
            </div>
        </div>

        <div class="p-4 rounded-4 shadow-sm bg-light">
            <!-- Day Filter (Optional) -->
            <template x-if="config.showDayFilter">
                <div class="mb-5">
                    <div class="segmented-control d-flex gap-1 p-1 bg-dark bg-opacity-10 rounded-pill">
                        <input type="radio" class="btn-check" name="day-filter" id="day-all" value="all" x-model="selectedDay">
                        <label class="btn btn-sm btn-outline-primary border-0 rounded-pill flex-fill py-2 fw-bold" for="day-all">Both</label>

                        <input type="radio" class="btn-check" name="day-filter" id="day-fri" value="Friday" x-model="selectedDay">
                        <label class="btn btn-sm btn-outline-primary border-0 rounded-pill flex-fill py-2 fw-bold" for="day-fri">Fri</label>

                        <input type="radio" class="btn-check" name="day-filter" id="day-sat" value="Saturday" x-model="selectedDay">
                        <label class="btn btn-sm btn-outline-primary border-0 rounded-pill flex-fill py-2 fw-bold" for="day-sat">Sat</label>
                    </div>
                </div>
            </template>

            <h5 class="fw-bold mb-4" style="color: var(--brand-marian-blue);">
                <i class="fas fa-filter me-2 small"></i>Filters
            </h5>

            <div class="d-flex flex-column gap-2">
                <!-- All Categories Toggle -->
                <div class="filter-item d-flex align-items-center justify-content-between p-3 rounded-4 transition-300 cursor-pointer"
                     :class="selectedTag === 'all' ? 'bg-brand-marian-blue text-white shadow' : 'bg-white text-dark hover-bg-light'"
                     @click="selectedTag = 'all'">
                    <div class="d-flex align-items-center">
                        <div class="filter-checkbox-custom me-3 rounded-circle border border-2 d-flex align-items-center justify-content-center"
                             :class="selectedTag === 'all' ? 'border-white bg-white-opacity-20' : 'border-secondary'">
                            <i class="fas fa-check small" x-show="selectedTag === 'all'"></i>
                        </div>
                        <span class="filter-label fw-bold">All</span>
                    </div>
                    <span class="badge rounded-pill bg-white text-dark small" x-text="items.length"></span>
                </div>

                <!-- Dynamic Tag Filters -->
                <template x-for="tag in uniqueTags">
                    <div class="filter-item d-flex align-items-center justify-content-between p-3 rounded-4 transition-300 text-capitalize cursor-pointer"
                         :class="selectedTag === tag ? 'bg-brand-marian-blue text-white shadow' : 'bg-white text-dark hover-bg-light'"
                         @click="selectedTag = tag">
                        <div class="d-flex align-items-center">
                            <div class="filter-checkbox-custom me-3 rounded-circle border border-2 d-flex align-items-center justify-content-center"
                                 :class="selectedTag === tag ? 'border-white bg-white-opacity-20' : 'border-secondary'">
                                <i class="fas fa-check small" x-show="selectedTag === tag"></i>
                            </div>
                            <span class="filter-label fw-bold" x-text="tag.replace(/-/g, ' ')"></span>
                        </div>
                        <span class="badge rounded-pill bg-white text-dark small"
                              x-text="items.filter(i => i.tags.includes(tag)).length"></span>
                    </div>
                </template>
            </div>
        </div>
    </aside>

    <!-- Main Content Area -->
    <div class="col-lg-9">
        <!-- Header Image -->
        <div class="text-center pt-5 mb-5">
            <img :src="config.titleImage" alt="Page Title" class="img-fluid"
                 style="max-height: min(150px, 90vw);">
        </div>

        <!-- Call to Action (Optional) -->
        <template x-if="config.cta.show">
            <div class="bg-brand-light-blue text-dark p-5 rounded-4 text-center mb-5 shadow">
                <h2 class="fw-bold mb-3" x-text="config.cta.title"></h2>
                <p class="fs-5 mb-4" x-text="config.cta.text"></p>
                <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                    <template x-if="config.cta.primaryBtn">
                        <a :href="config.cta.primaryBtn.url" class="btn btn-warning btn-lg fw-bold px-4" target="_blank">
                            <i :class="config.cta.primaryBtn.icon + ' me-2'"></i> <span x-text="config.cta.primaryBtn.text"></span>
                        </a>
                    </template>
                    <template x-if="config.cta.secondaryBtn">
                        <a :href="config.cta.secondaryBtn.url" class="btn btn-outline-dark btn-lg fw-bold px-4">
                            <i :class="config.cta.secondaryBtn.icon + ' me-2'"></i> <span x-text="config.cta.secondaryBtn.text"></span>
                        </a>
                    </template>
                </div>
            </div>
        </template>

        <!-- Items Grid -->
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            <template x-for="item in filteredItems" :key="item.name">
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative group transition-300 hover-lift">
                        <!-- Card Image -->
                        <img :src="(window.siteConfig?.pathPrefix || '/') + item.image" class="card-img object-fit-cover" :alt="item.name" style="height: 380px;">

                        <!-- Dark Gradient Overlay -->
                        <div class="card-img-overlay d-flex flex-column justify-content-end p-4 bg-gradient-dark-strong transition-300 group-hover-darken">
                            <template x-if="item.days">
                                <div class="position-absolute top-0 start-0 m-3 d-flex gap-1" style="z-index: 10;">
                                    <template x-for="day in item.days">
                                        <span class="badge rounded-pill shadow-sm px-3 py-1 fw-bold" style="font-size: 0.7rem;" x-text="day"></span>
                                    </template>
                                </div>
                            </template>

                            <!-- Sponsor Badge (Top Right) -->
                            <template x-if="item.sponsor">
                                <a :href="item.sponsor.url" target="_blank" class="sponsor-badge text-decoration-none">
                                    <span class="sponsor-label">Sponsored by</span>
                                    <div class="sponsor-name-container">
                                        <span class="sponsor-name" x-text="item.sponsor.name"></span>
                                    </div>
                                </a>
                            </template>

                            <!-- Card Content (Bottom) -->
                            <div class="content-wrapper">
                                <h4 class="card-title text-white fw-bold text-shadow mb-1" x-text="item.name"></h4>
                                <p class="card-text text-white-50 small mb-3 line-clamp-2 text-shadow-subtle" x-text="item.description"></p>

                                <div class="d-flex justify-content-between align-items-center">
                                    <!-- Category Tags -->
                                    <div class="d-flex flex-wrap gap-1">
                                        <template x-for="tag in item.tags">
                                            <span class="badge rounded-pill shadow-sm text-capitalize px-2 py-1"
                                                  :class="getTagColorClass(tag)"
                                                  style="font-size: 0.65rem;"
                                                  x-text="tag.replace(/-/g, ' ')">
                                            </span>
                                        </template>
                                    </div>

                                    <!-- Visit Button -->
                                    <template x-if="item.url && item.url !== '#'">
                                        <a :href="item.url" class="btn btn-white btn-sm rounded-circle shadow-sm ms-2 p-2 d-flex align-items-center justify-content-center transition-300 hover-scale"
                                           style="width: 32px; height: 32px;" target="_blank">
                                            <i class="fas fa-external-link-alt" style="font-size: 0.75rem;"></i>
                                        </a>
                                    </template>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </template>
        </div>

        <!-- No Results State -->
        <template x-if="filteredItems.length === 0">
            <div class="text-center py-5">
                <i class="fas fa-search fa-3x mb-3 text-muted opacity-50"></i>
                <h4 class="fw-bold text-muted" x-text="config.noResultsText"></h4>
                <p class="text-muted">Try adjusting your filters.</p>
            </div>
        </template>
    </div>
</div>

<!-- Floating Action Button for Mobile Filters -->
<button class="fab-filter d-lg-none" type="button" data-bs-toggle="offcanvas"
    data-bs-target="#offcanvasFilters" aria-controls="offcanvasFilters">
    <i class="fas fa-filter"></i>
</button>

<!-- Offcanvas Mobile Filters -->
<div class="offcanvas offcanvas-bottom rounded-top-4" tabindex="-1" id="offcanvasFilters"
aria-labelledby="offcanvasFiltersLabel" style="height: auto; max-height: 85vh;">
    <div class="offcanvas-header border-bottom py-3">
        <h5 class="offcanvas-title fw-bold" id="offcanvasFiltersLabel" style="color: var(--brand-marian-blue);">
            <i class="fas fa-sliders-h me-2"></i>Filters
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
    </div>
    <div class="offcanvas-body p-4">
        <!-- Gallery Switcher (Mobile) -->
        <div class="mb-4">
            <h6 class="fw-bold mb-3 text-muted small text-uppercase letter-spacing-1">Page</h6>
            <div class="segmented-control d-flex gap-1 p-1 bg-dark bg-opacity-10 rounded-pill">
                <a href="{{ "/pages/stalls.html" | url }}" class="btn btn-sm border-0 rounded-pill flex-fill py-2 fw-bold transition-200"
                   :class="currentKey === 'stalls' ? 'bg-white shadow text-primary' : 'text-muted hover-dark-tiny'">Stalls</a>
                <a href="{{ "/pages/food.html" | url }}" class="btn btn-sm border-0 rounded-pill flex-fill py-2 fw-bold transition-200"
                   :class="currentKey === 'food' ? 'bg-white shadow text-primary' : 'text-muted hover-dark-tiny'">Food</a>
                <a href="{{ "/entertainment.html" | url }}" class="btn btn-sm border-0 rounded-pill flex-fill py-2 fw-bold transition-200"
                   :class="currentKey === 'entertainment' ? 'bg-white shadow text-primary' : 'text-muted hover-dark-tiny'">Events</a>
            </div>
        </div>

        <!-- Day Filter (Mobile) -->
        <template x-if="config.showDayFilter">
            <div class="mb-4">
                <h6 class="fw-bold mb-3 text-muted small text-uppercase letter-spacing-1">Day</h6>
                <div class="btn-group w-100 segmented-control" role="group">
                    <input type="radio" class="btn-check" name="day-filter-mobile" id="day-all-mobile" value="all" x-model="selectedDay">
                    <label class="btn btn-outline-primary py-2" for="day-all-mobile">Both</label>

                    <input type="radio" class="btn-check" name="day-filter-mobile" id="day-fri-mobile" value="Friday" x-model="selectedDay">
                    <label class="btn btn-outline-primary py-2" for="day-fri-mobile">Fri</label>

                    <input type="radio" class="btn-check" name="day-filter-mobile" id="day-sat-mobile" value="Saturday" x-model="selectedDay">
                    <label class="btn btn-outline-primary py-2" for="day-sat-mobile">Sat</label>
                </div>
            </div>
        </template>

        <h6 class="fw-bold mb-3 text-muted small text-uppercase letter-spacing-1">Categories</h6>
        <div class="mobile-filter-grid overflow-auto pb-2" style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px;">
            <!-- All Categories Toggle -->
            <div class="filter-item text-center p-2 rounded-3 border transition-200 cursor-pointer"
                 :class="selectedTag === 'all' ? 'bg-brand-marian-blue text-white border-brand-marian-blue shadow-sm' : 'bg-light text-dark border-light-subtle'"
                 @click="selectedTag = 'all'">
                <span class="small fw-bold">All</span>
            </div>
            <!-- Dynamic Tag Filters -->
            <template x-for="tag in uniqueTags">
                <div class="filter-item text-center p-2 rounded-3 border transition-200 text-capitalize cursor-pointer"
                     :class="selectedTag === tag ? 'bg-brand-marian-blue text-white border-brand-marian-blue shadow-sm' : 'bg-light text-dark border-light-subtle'"
                     @click="selectedTag = tag">
                    <span class="small fw-bold" x-text="tag.replace(/-/g, ' ')"></span>
                </div>
            </template>
        </div>

        <div class="mt-4 pt-2">
            <button type="button" class="btn btn-brand-marian-blue w-100 rounded-pill py-3 fw-bold shadow-sm" data-bs-dismiss="offcanvas">
                Show Results
            </button>
        </div>
    </div>
</div>
