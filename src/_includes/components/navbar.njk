<!-- navbar.njk: Dynamic menu driven by src/_data/navigation.js -->
<nav id="main-navbar" class="navbar navbar-expand-md py-3">
    <div class="container-fluid px-4">
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
            aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto">

                <!-- Home link -->
                <li class="nav-item">
                    <a class="nav-link {% if page.url == ('/' | url) %}active{% endif %}" href="{{ '/' | url }}">Home</a>
                </li>

                <!-- Dynamic dropdowns from _data/navigation.js -->
                {%- for group in navigation %}
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" role="button"
                        data-bs-toggle="dropdown" aria-expanded="false">
                        {{ group.key }}
                    </a>
                    <ul class="dropdown-menu border-0 shadow-lg">
                        {%- for item in group.children %}
                            {%- if item.divider %}
                            <li><hr class="dropdown-divider"></li>
                            {%- elif item.header %}
                            <li>
                                <h6 class="dropdown-header">
                                    {%- if item.icon %}<i class="{{ item.icon }} me-2"></i>{% endif %}
                                    {{ item.header }}
                                </h6>
                            </li>
                            {%- else %}
                            <li>
                                <a class="dropdown-item {% if item.url and (item.url | url) == page.url %}active{% endif %}"
                                    href="{{ item.url | url }}">
                                    {%- if item.icon %}<i class="{{ item.icon }} me-2"></i>{% endif %}
                                    {{ item.label }}
                                </a>
                            </li>
                            {%- endif %}
                        {%- endfor %}
                    </ul>
                </li>
                {%- endfor %}

            </ul>
            <!-- Controls: Countdown -->
            <div class="d-flex align-items-center ms-auto" x-data>
                <span id="countdown-timer" x-data="countdown" x-text="timeLeft"
                    class="navbar-text text-dark d-none d-md-inline" style="font-size: 0.9rem;">
                </span>
            </div>
        </div>
    </div>
</nav>
