{% from "components/sticker-button.njk" import stickerButton %}

<footer class="footer-v2 position-relative overflow-hidden d-none d-md-block">
    <!-- Rotated Background Layers -->
    <div class="footer-bg-pink"></div>
    <div class="footer-bg-yellow"></div>
    <div class="footer-bg-green"></div>

    <div class="container position-relative" style="z-index: 10;">

        <!-- Footer Heading -->
        <div class="text-center mb-5">
            <h2 class="footer-v2-title">See You There!</h2>
            <p class="footer-v2-subtitle">Fri 10 – Sat 11 July 2026 · Girton Recreation Ground</p>
        </div>

        <!-- Card Wrapper -->
        <div class="footer-v2-card-wrapper">
            <!-- Decorative rotated cards behind -->
            <div class="footer-v2-card-bg footer-v2-card-bg-pink"></div>
            <div class="footer-v2-card-bg footer-v2-card-bg-yellow"></div>

            <!-- Main Content Card -->
            <div class="footer-v2-card shadow-lg p-5">
                <!-- Silly Goose Background -->
                <img src="{{ "/images/silly_goose.svg" | url }}" alt="" class="footer-goose-bg position-absolute bottom-0 end-0 opacity-10 pointer-events-none" style="width: 240px; transform: rotate(-15deg) translate(20px, 20px); z-index: 0;">

                <div class="row g-5 position-relative" style="z-index: 1;">
                    <!-- About Section -->
                    <div class="col-lg-4 col-md-6">
                        <h5 class="footer-v2-col-heading">Girton Feast {% year %}</h5>
                        <p class="footer-v2-body mb-4">A weekend of live music, food, fun, and festivities for the whole village community.</p>

                        <div class="d-flex align-items-center mb-2 footer-v2-body">
                            <i class="fas fa-calendar-alt me-2" style="color: var(--brand-v2-purple);"></i>
                            <span>Fri 10 – Sat 11 July 2026</span>
                        </div>
                        <div class="d-flex align-items-center mb-4 footer-v2-body">
                            <i class="fas fa-map-marker-alt me-2" style="color: var(--brand-v2-purple);"></i>
                            <span>Girton Recreation Ground</span>
                        </div>

                        <div class="mt-3">
                            {{ stickerButton("Get Tickets →", "#concert-details") }}
                        </div>
                    </div>

                    <!-- Quick Links -->
                    <div class="col-lg-2 col-md-6">
                        <h6 class="footer-v2-col-heading">Explore</h6>
                        <ul class="list-unstyled footer-v2-links">
                            <li><a href="{{ "/entertainment.html" | url }}">Entertainment</a></li>
                            <li><a href="{{ "/pages/food.html" | url }}">Food &amp; Drink</a></li>
                            <li><a href="{{ "/pages/gallery.html" | url }}">Gallery</a></li>
                            <li><a href="{{ "/pages/getting-here.html" | url }}">Getting Here</a></li>
                            <li><a href="{{ "/map.html" | url }}">Map</a></li>
                        </ul>
                    </div>

                    <!-- For Vendors -->
                    <div class="col-lg-2 col-md-6">
                        <h6 class="footer-v2-col-heading">For Vendors</h6>
                        <ul class="list-unstyled footer-v2-links">
                            <li><a href="{{ "/info/stall-holders.html" | url }}">Stall Holders</a></li>
                            <li><a href="{{ "/info/caterers-info.html" | url }}">Food Vendors</a></li>
                            <li><a href="{{ "/info/ride-vendors-info.html" | url }}">Rides &amp; Games</a></li>
                        </ul>
                    </div>

                    <!-- Contact & Social -->
                    <div class="col-lg-4 col-md-6">
                        <h6 class="footer-v2-col-heading">Get In Touch</h6>
                        <p class="footer-v2-body mb-3">Questions or want to help out?</p>

                        <a href="{{ "/pages/contact.html" | url }}" class="footer-v2-contact-btn mb-4">
                            <i class="fas fa-envelope me-2"></i>Contact Us
                        </a>

                        <div class="d-flex gap-2 mb-4 mt-3">
                            <a href="https://www.facebook.com/GirtonFeastWeek"
                                class="footer-v2-social-icon"
                                aria-label="Facebook" target="_blank">
                                <i class="fab fa-facebook-f"></i>
                            </a>
                            <a href="https://youtu.be/0FqhvdgCn3E?si=2SnO4hMgtZKrgjjJ"
                                class="footer-v2-social-icon"
                                aria-label="Youtube" target="_blank">
                                <i class="fab fa-youtube"></i>
                            </a>
                            <a href="https://nextdoor.co.uk/search/?view=detail&init_source=search&query=%23girtonfeast&ccid=93bf984a-9a4c-401f-a5f8-c9bdcf0ba673&navigationScreen=POST&ssid=9fddbc32-dc0e-4d66-b684-c5e393c3f17a"
                                class="footer-v2-social-icon"
                                aria-label="Nextdoor" target="_blank">
                                <img src="{{ "/images/nextdoor-icon.svg" | url }}" alt="Nextdoor" style="width: 1em; height: 1em; filter: brightness(0) invert(1);">
                            </a>
                        </div>

                        <p class="footer-v2-hashtag">#GirtonFeast</p>

                        <!-- Organized by -->
                        <div class="mt-4 pt-4 border-top border-black border-opacity-10">
                            <p class="footer-v2-body small mb-2" style="opacity: 0.6;">Organised by</p>
                            <img src="{{ "/images/gvc_logo.png" | url }}" alt="Girton Village Celebrations"
                                class="img-fluid bg-white p-2 rounded-2"
                                style="max-height: 60px;">
                        </div>
                    </div>
                </div>

                <!-- Bottom Bar -->
                <hr class="my-4" style="border-color: rgba(0,0,0,0.1);">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-2">
                    <p class="footer-v2-body small mb-0" style="opacity: 0.55;">
                        © <span x-data x-text="new Date().getFullYear()">2026</span> Girton Village Celebrations. All rights reserved.
                    </p>
                    <div class="d-flex gap-3">
                        <a href="{{ "/#sponsors" | url }}" class="footer-v2-bottom-link">Sponsors</a>
                        <a href="{{ "/#get-involved" | url }}" class="footer-v2-bottom-link">Get Involved</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</footer>
