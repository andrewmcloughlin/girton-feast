{% macro eventCard(title, subtitle, image, color, link="#", rotationClass="") %}
<div class="event-card-wrapper {{ rotationClass }} animate-on-scroll">
    <a href="{{ link | url }}" class="event-card" style="background-color: {{ color }};">
        <div class="event-card-content">
            <h3 class="event-card-title">{{ title }}</h3>
            <span class="event-card-subtitle">{{ subtitle }}</span>
        </div>
        <div class="event-card-image-wrapper">
            <img src="{{ ("/images/" + image) | url }}" alt="{{ title }}" class="event-card-image">
        </div>
    </a>
</div>
{% endmacro %}
