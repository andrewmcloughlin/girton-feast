<!-- Floating Scrollspy Sidebar (Wide Screens Only) -->
<nav id="scrollspy-sidebar" class="d-none d-xxl-block position-fixed translate-middle-y"
     style="top: 50%; right: 2rem; width: 250px; z-index: 1040;"
     x-data="{
        activeSection: '',
        sections: [],
        init() {
            this.sections = Array.from(document.querySelectorAll('#sidebar-nav .nav-link')).map(link => {
                const id = link.getAttribute('href').substring(1);
                return { id, element: document.getElementById(id) };
            }).filter(s => s.element);

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        this.activeSection = entry.target.id;
                    }
                });
            }, { rootMargin: '-10% 0px -80% 0px', threshold: 0 });

            this.sections.forEach(s => observer.observe(s.element));
        }
     }">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden"
         style="background: rgba(var(--bs-white-rgb), 0.85); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);">
        <div class="card-body p-4">
            <h6 class="fw-bold mb-3 text-primary" style="font-family: 'Poller One', cursive;">Navigation</h6>
            <div class="nav flex-column nav-pills" id="sidebar-nav">
                <template x-for="link in [
                    { id: 'hero-section', label: 'Home' },
                    { id: 'concert-details', label: 'Evening Concert' },
                    { id: 'whatson', label: 'What\'s On?' },
                    { id: 'amenities', label: 'Amenities' },
                    { id: 'vendor-info', label: 'Vendor Info' },
                    { id: 'get-involved', label: 'Get Involved' },
                    { id: 'sponsors', label: 'Sponsors' }
                ]">
                    <a class="nav-link mb-1 rounded-3 transition-300"
                       :class="activeSection === link.id ? 'active bg-primary text-white shadow-sm' : 'text-secondary hover-bg-light'"
                       :href="'#' + link.id"
                       x-text="link.label"></a>
                </template>
            </div>
            <div class="mt-3 pt-3 border-top">
                <a href="https://www.ticketsource.co.uk/girtonfeast" target="_blank" rel="noopener noreferrer"
                   class="btn btn-warning w-100 fw-bold rounded-pill shadow-sm hover-scale transition-300">
                    <i class="fas fa-ticket-alt me-2"></i>Book Tickets
                </a>
            </div>
        </div>
    </div>
</nav>
