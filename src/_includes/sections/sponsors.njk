{% set sponsorRotations = ["rotate-left-sm", "rotate-right-xs", "rotate-left-xs", "rotate-right-sm", "rotate-right-xs", "rotate-left-xs"] %}

<!-- Sponsors section -->
<section id="sponsors" class="sponsors-section py-5 my-5 overflow-hidden">
    <div class="container text-center mb-5">
    <img src="{{ ('/images/titles/sponsors-text.png') | url }}" alt="Sponsors" class="img-fluid mb-4" style="max-width: 900px; width: 100%;">
        <p class="sponsors-subtitle">
            Girton Feast is run entirely by volunteers and funded by brilliant local businesses.<br>
            We're endlessly grateful to everyone who makes it possible.
        </p>
        <a href="{{ '/pages/contact.html' | url }}" class="whats-on-link">Become a sponsor →</a>
    </div>

    <div class="marquee-wrapper">
        <div class="marquee-content">
            {% for sponsor in sponsors %}
                {% set rotation = sponsorRotations[loop.index0 % 6] %}
                <div class="sponsor-logo-wrapper {{ rotation }}">
                    {% if sponsor.url %}
                        <a href="{{ sponsor.url }}" target="_blank" rel="noopener noreferrer">
                            <img src="{{ ('/images/sponsors/' + sponsor.image) | url }}"
                                 alt="Logo of an official event sponsor."
                                 class="sponsor-logo-img">
                        </a>
                    {% else %}
                        <img src="{{ ('/images/sponsors/' + sponsor.image) | url }}"
                             alt="Logo of an official event sponsor."
                             class="sponsor-logo-img">
                    {% endif %}
                </div>
            {% endfor %}
            <!-- Duplicate for seamless loop -->
            {% for sponsor in sponsors %}
                {% set rotation = sponsorRotations[loop.index0 % 6] %}
                <div class="sponsor-logo-wrapper {{ rotation }}">
                    {% if sponsor.url %}
                        <a href="{{ sponsor.url }}" target="_blank" rel="noopener noreferrer">
                            <img src="{{ ('/images/sponsors/' + sponsor.image) | url }}"
                                 alt="Logo of an official event sponsor."
                                 class="sponsor-logo-img">
                        </a>
                    {% else %}
                        <img src="{{ ('/images/sponsors/' + sponsor.image) | url }}"
                             alt="Logo of an official event sponsor."
                             class="sponsor-logo-img">
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
</section>
