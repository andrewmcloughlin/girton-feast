<section id="hero-section" class="hero-v2 container-fluid">
    <div class="container pt-5 pb-2">
        <div class="row align-items-start">
            <!-- Left Column: Content -->
            <div class="col-lg-5 mb-5 mb-lg-0">
                <div class="hero-v2-header">
                    <h1 class="hero-v2-title">
                        Girton<br>Feast<span class="hero-v2-year ps-1 pb-2 fs-1">{% year %}</span>
                    </h1>
                </div>

                <div class="hero-v2-detail">
                    <p class="mb-1">Fri 10th July - Evening concert</p>
                    <p class="mb-1">Sat 11th July - Village Fete</p>
                    <p>Girton Recreation Ground</p>
                </div>

                <div class="hero-v2-buttons">
                    <a href="#concert-details" class="btn btn-v2-primary shadow-sm">Get Concert tickets &rarr;</a>
                    <a href="#whatson" class="btn btn-v2-outline shadow-sm">See fete activities &rarr;</a>
                </div>

                <p class="text-muted small">* free entry</p>
            </div>

            <!-- Right Column: Visuals -->
            <div class="col-lg-7">
                <div class="hero-v2-visual">
                    <svg viewBox="-50 -100 950 650" xmlns="http://www.w3.org/2000/svg" class="blob-svg" style="overflow: visible;">
                        <defs>
                            <!-- Single Source of Truth for Paths -->
                            <path id="morph-pink" d="M280.6,416.9C405.1,444.5,536.4,541.2,676.7,486.8C827.2,437.1,802.3,323,810.2,213.4C818.2,103.9,743.5,15.5,381.4,0.8C19.3,-14,-33.9,187.6,15.9,268.7C65.7,349.7,156.2,389.3,280.6,416.9Z" />
                            <!-- Shipped Green Path (Baked +60X, -40Y) -->
                            <path id="morph-green" d="M385,440.9C259.3,427.4,126.7,492.7,77.4,395.5C28.1,298.4,62.9,38.8,171.4,-18.2C279.9,-75.3,462.1,70.2,564.6,143.1C667,215.9,689.6,216.1,684.5,308.6C679.3,401.1,646.4,469.3,570.8,478.2C495.1,487.1,510.7,454.5,385,440.9Z" />

                            <clipPath id="clip-pink">
                                <use href="#morph-pink" />
                            </clipPath>
                            <clipPath id="clip-green">
                                <use href="#morph-green" />
                            </clipPath>
                        </defs>

                        <!-- Background Blobs (Synced) -->
                        <use href="#morph-pink" class="blob-bg-pink" />
                        <use href="#morph-green" class="blob-bg-green" />

                        <!-- Masked Image: Intersection of A and B via nested clipping -->
                        <!-- This is the most robust way to ensure 100% opacity and zero offset -->
                        <g clip-path="url(#clip-pink)">
                            <g clip-path="url(#clip-green)">
                                <foreignObject x="-100" y="-120" width="1100" height="850">
                                    <img src="{{ "/images/map-thumbnail.png" | url }}"
                                         alt="Girton Feast Map"
                                         class="map-image-redesign" />
                                </foreignObject>
                            </g>
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </div>
</section>
