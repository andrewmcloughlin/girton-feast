<section id="hero-section" class="container-fluid bg-brand-glaucous content-container pb-0 px-0">
    <div class="text-center mb-4">
        <h1 class="display-1 fw-bold mb-0">
            <img src="{{ "/images/girton-feast-logo-text.svg" | url }}" alt="Girton Feast Logo" class="img-fluid hero-logo"
                style="max-height: clamp(250px, 50vh, 650px)">
        </h1>
        <div x-data="{
            year: new Date().getFullYear().toString(),
            get digits() { return this.year.split(''); }
        }">
            <template x-for="(digit, index) in digits" :key="index">
                <img :src="`${window.siteConfig?.pathPrefix || '/'}images/digits/${digit}.svg`" :alt="digit" class="img-fluid"
                    style="max-height: clamp(50px, 10vh, 50px)">
            </template>
        </div>
    </div>
    <div class="p-4">
        <div class="d-flex flex-column flex-sm-row justify-content-center align-items-center text-center gap-3 d-none d-md-block">
            <template x-if="$store.app.eventInfo">
                <div class="btn-group rounded-pill overflow-hidden shadow-sm" role="group" aria-label="Event navigation">
                    <a
                        class="btn text-white bg-brand-marian-blue p-3 px-4 fs-6 text-decoration-none hover-scale border-end border-white-25"
                        href="#concert-details">
                        <b x-text="$store.app.eventInfo.main_event.date_short + ' - Concert'"></b>
                    </a>
                    <a
                        class="btn text-white bg-brand-marian-blue p-3 px-4 fs-6 text-decoration-none hover-scale border-start border-white-25"
                        href="#whatson">
                        <b x-text="$store.app.eventInfo.village_fete.date_short + ' - Village Fete'"></b>
                    </a>
                </div>
            </template>
            <div class="btn-group rounded-pill overflow-hidden shadow-sm" role="group" aria-label="Calendar events">
                <a target="_blank"
                    class="btn text-white bg-brand-marian-blue p-3 px-4 fs-6 text-decoration-none hover-scale"
                    href="{{ "/pages/getting-here.html" | url }}">
                    <b>Girton Rec</b>
                </a>
            </div>
        </div>
        <template x-if="$store.app.eventInfo">
            <div class="d-flex flex-column flex-sm-row justify-content-center text-center gap-2 d-block d-md-none">
                <a class="switcher-btn switcher-btn-pink rotate-neg-2" href="https://www.ticketsource.com/girtonfeast" target="_blank">
                    <i class="fas fa-ticket-alt me-2"></i>Claim your tickets →
                </a>
                <a class="switcher-btn switcher-btn-pink rotate-pos-2" href="#whatson">
                    See Fete Activities →
                </a>
            </div>
        </template>
    </div>
    <div class="text-center pt-4 text-white">
        <p id="event-description" class="lead fs-4">
            Join us for a weekend of <strong class="text-brand-thulian-pink">live music</strong>, <strong
                class="text-brand-glaucous">food</strong>, <strong class="text-brand-giants-orange">fun</strong>,
            and <strong class="text-brand-marian-blue">festivities</strong>.
        </p>
    </div>
    {% image "/images/map/hero-map.png", "A wide, aerial view of the Girton Feast event grounds, showing tents, stalls, and a large grassy field.", "100vw", "img-fluid mx-auto d-block mb-0", "eager", "max-width: 100%; height: auto;" %}
</section>
