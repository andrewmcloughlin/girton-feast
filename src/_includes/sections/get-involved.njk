{% from "components/sticker-button.njk" import stickerButton %}

<section id="get-involved" class="get-involved-section py-5 my-5">
    <div class="container text-center mb-5">
        <h2 class="get-involved-title">Lend a hand, spread the love</h2>
    </div>

    <div class="container">
        <div class="row g-4 justify-content-center">
            <!-- Share your wares -->
            <div class="col-12 col-md-6">
                <div class="involvement-card rotate-left-sm animate-on-scroll" style="background-color: #EABEFF;">
                    <h3 class="involvement-card-title">Share your wares</h3>
                    <p class="involvement-card-text">Got something local to share? From crafts to cakes, we'd love to showcase your wares at the Feast.</p>
                    <div class="involvement-card-footer">
                        {{ stickerButton("Contact the team", "/pages/contact.html") }}
                    </div>
                </div>
            </div>

            <!-- Lend a Hand -->
            <div class="col-12 col-md-6">
                <div class="involvement-card rotate-right-xs animate-on-scroll" style="background-color: #E3FFC0;">
                    <h3 class="involvement-card-title">Lend a Hand</h3>
                    <p class="involvement-card-text">Many hands make light work! Whether it's putting up bunting or helping on the big day, we need you.</p>
                    <div class="involvement-card-footer">
                        {{ stickerButton("Contact the team", "/pages/contact.html") }}
                    </div>
                </div>
            </div>

            <!-- Spread the love -->
            <div class="col-12 col-md-6">
                <div class="involvement-card rotate-left-xs animate-on-scroll" style="background-color: #C8FFE0;">
                    <h3 class="involvement-card-title">Spread the love</h3>
                    <p class="involvement-card-text">Girton Feast is better with friends. Use #girtonfeast to help us reach more of the community.</p>
                    <div class="involvement-card-footer">
                        <span class="involvement-hashtag">#girtonfeast</span>
                    </div>
                </div>
            </div>

            <!-- Get in Touch -->
            <div class="col-12 col-md-6">
                <div class="involvement-card rotate-right-sm animate-on-scroll" style="background-color: #FFBEF7;">
                    <h3 class="involvement-card-title">Get in Touch</h3>
                    <p class="involvement-card-text">Got a question? We're here to help. Reach out and our friendly team will get back to you.</p>
                    <div class="involvement-card-footer">
                        {{ stickerButton("Contact the team", "/pages/contact.html") }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
