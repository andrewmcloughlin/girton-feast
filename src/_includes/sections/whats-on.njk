{% from "components/event-card.njk" import eventCard %}

<section class="whats-on-section py-5 my-5">
    <div class="container text-center mb-5">
        <h2 class="whats-on-title">Something for Everyone</h2>
        <a href="{{ "/events/" | url }}" class="whats-on-link">See all events →</a>
    </div>

    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-6 col-md-3">
                {{ eventCard("Live Music", "See the line-up →", "singer.png", "#EABEFF", "/events/music/", "rotate-left-sm") }}
            </div>
            <div class="col-6 col-md-3">
                {{ eventCard("Sports", "Explore →", "tower.png", "#E3FFC0", "/events/sports/", "rotate-right-xs") }}
            </div>
            <div class="col-6 col-md-3">
                {{ eventCard("Displays", "See the line-up →", "plane.png", "#C8FFE0", "/events/displays/", "rotate-left-xs") }}
            </div>
            <div class="col-6 col-md-3">
                {{ eventCard("Family Fun", "See all →", "stilts.png", "#FFBEF7", "/events/family/", "rotate-right-sm") }}
            </div>
        </div>
    </div>
</section>
