{% from "components/event-card.njk" import eventCard %}

<section id="activities" class="whats-on-section py-5 my-5">
    <div class="container text-center mb-5">
    <img src="{{ ('/images/titles/whats-on-text.svg') | url }}" alt="What's On" class="img-fluid mb-4" style="max-width: 900px; width: 100%;">
    <br>
        <a href="{{ "/entertainment.html" | url }}" class="whats-on-link">See all events →</a>
    </div>

    <div class="container">
        <div class="row g-4 justify-content-center">
            <div class="col-6 col-lg-3">
                {{ eventCard("Live Music", "See the line-up →", "singer.png", "var(--brand-yellow)", "/entertainment.html?tag=music", "rotate-left-sm") }}
            </div>
            <div class="col-6 col-lg-3">
                {{ eventCard("Sports", "Explore →", "tower.png", "var(--brand-pastel-green)", "/entertainment.html?tag=sports", "rotate-right-xs") }}
            </div>
            <div class="col-6 col-lg-3">
                {{ eventCard("Displays", "See the line-up →", "plane.png", "var(--brand-pastel-purple)", "/entertainment.html?tag=shows", "rotate-left-xs") }}
            </div>
            <div class="col-6 col-lg-3">
                {{ eventCard("Family Fun", "See all →", "pompom-transparent.png", "var(--brand-yellow)", "/entertainment.html?tag=kids", "rotate-right-sm") }}
            </div>
        </div>
    </div>
</section>
