<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or "Girton Feast" }}</title>

    <!-- Bootstrap CSS from CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Preload the LCP image -->
    <link rel="preload" fetchpriority="high" as="image" href="{% imageUrl "/images/hero.png" %}" type="image/webp">
    <link rel="preload" href="{{ '/images/map-lg.svg' | url }}" as="image" type="image/svg+xml">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sigmar+One&family=Poller+One&family=Spicy+Rice&family=Glass+Antiqua&family=Annie+Use+Your+Telescope&family=Comfortaa:wght@300..700&family=DynaPuff:wght@400..700&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    {% block extra_head %}{% endblock %}

    <!-- Custom CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <!-- Custom Stylesheet -->
    <link rel="stylesheet" href="{{ "/css/style.css" | url }}">

    <!-- Alpine.js -->
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="{{ "/images/favicons/apple-touch-icon.png" | url }}">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ "/images/favicons/favicon-32x32.png" | url }}">
    <link rel="icon" type="image/png" sizes="16x16" href="{{ "/images/favicons/favicon-16x16.png" | url }}">
    <link rel="shortcut icon" href="{{ "/images/favicons/favicon.ico" | url }}">

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-P2D103WGWN"></script>
    <script>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', 'G-P2D103WGWN');

        window.siteConfig = {
            pathPrefix: "{{ '/' | url }}",
            eventInfo: {{ event_info | dump | safe }}
        };
    </script>
</head>
<body data-bs-spy="scroll" data-bs-target="#main-navbar" data-bs-smooth-scroll="true" tabindex="0"
    class="px-0 mx-0 w-100 bg-light {{ bodyClass }}" x-data x-on:keydown.window="$store.app.handleKonami($event.key)">

    {% include "components/navbar.njk" %}

    <main>
        {% include "components/breadcrumbs.njk" %}
        {{ content | safe }}
    </main>

    {% if not hideFooter %}
    {% include "components/footer.njk" %}
    {% endif %}

    <!-- Scroll to top button -->
    <button x-data x-show="$store.app.scrolled"
            @click="$store.app.scrollToTop()"
            id="scrollToTopBtn"
            title="Go to top"
            x-cloak
            style="display: none;"
            :style="$store.app.scrolled ? 'display: flex' : 'display: none'">
        <i class="fas fa-arrow-up"></i>
    </button>

    {% include "components/mobile-nav.njk" %}

    <!-- Bootstrap JS Bundle from CDN -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="{{ "/js/script.js" | url }}"></script>

    {% block extra_scripts %}{% endblock %}
    <!-- Scroll Animation Script -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const observerOptions = {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('is-visible');
                    }
                });
            }, observerOptions);

            document.querySelectorAll('.animate-on-scroll').forEach(el => {
                observer.observe(el);
            });
        });
    </script>
</body>
</html>
