---
layout: layouts/base.njk
title: Getting Here - Girton Feast
permalink: /pages/getting-here.html
bodyClass: bg-brand-light-blue
---

{% block extra_head %}
<!-- Leaflet -->
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
{% endblock %}

<main class="container my-5">
    <div class="text-center pt-5 mb-5">
        <h1 class="display-4" style="font-family: 'Sigmar One', cursive; color: var(--brand-marian-blue);">Getting to the Event</h1>
        <p class="lead text-muted">Find us at Girton Recreation Ground, Cambridge Road, CB3 0PG</p>
    </div>

    <!-- Interactive Map -->
    <div id="map" class="shadow-lg" style="height: 450px; width: 100%; border-radius: 1rem; margin-bottom: 3rem; z-index: 1;"></div>
    <!-- Transport Options -->
    <div class="row g-4">
        <!-- By Car -->
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <i class="fas fa-car fa-3x me-4" style="color: var(--brand-glaucous);"></i>
                    <div>
                        <h5 class="card-title fw-bold" style="color: var(--brand-marian-blue);">By Car</h5>
                        <p class="card-text mb-0">Limited parking is available. We encourage using public transport or cycling where possible. Please park considerately.</p>
                        <a href="https://maps.app.goo.gl/SpqWztHDsx1rBLwk6" target="_blank" class="stretched-link"></a>
                    </div>
                </div>
            </div>
        </div>
        <!-- By Bus -->
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <i class="fas fa-bus fa-3x me-4" style="color: var(--brand-thulian-pink);"></i>
                    <div>
                        <h5 class="card-title fw-bold" style="color: var(--brand-marian-blue);">By Bus</h5>
                        <p class="card-text mb-0">The Citi 6 bus route stops near the recreation ground. Check local timetables for details.</p>
                        <a href="https://www.stagecoachbus.com/routes/east/6/cambridge-oakington/XEAO006.O" target="_blank" class="stretched-link"></a>
                    </div>
                </div>
            </div>
        </div>
        <!-- By Bike -->
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <i class="fas fa-bicycle fa-3x me-4" style="color: var(--brand-saffron);"></i>
                    <div>
                        <h5 class="card-title fw-bold" style="color: var(--brand-marian-blue);">By Bike</h5>
                        <p class="card-text mb-0">Ample cycle parking is available. We encourage you to cycle to the event!</p>
                    </div>
                </div>
            </div>
        </div>
        <!-- By Taxi -->
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <i class="fas fa-taxi fa-3x me-4" style="color: var(--brand-giants-orange);"></i>
                    <div>
                        <h5 class="card-title fw-bold" style="color: var(--brand-marian-blue);">By Taxi</h5>
                        <p class="card-text mb-0">Our event is proudly sponsored by Veezu. Book your ride with a local, reliable service.</p>
                        <a href="https://www.veezu.co.uk/" target="_blank" rel="noopener noreferrer" class="stretched-link"></a>
                    </div>
                </div>
            </div>
        </div>
        <!-- what3words Card -->
        <div class="col-lg-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body d-flex align-items-center">
                    <i class="fas fa-map-signs fa-3x me-4" style="color: var(--brand-marian-blue);"></i>
                    <div>
                        <h5 class="card-title fw-bold" style="color: var(--brand-marian-blue);">what3words</h5>
                        <p class="card-text mb-0">For a precise location, find us at ///rise.smile.magic</p>
                        <a href="https://what3words.com/rise.smile.magic" target="_blank" rel="noopener noreferrer" class="stretched-link"></a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

{% block extra_scripts %}
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script>
    // Initialize Leaflet Map
    const mapCoords = [52.2405, 0.0855]; // Coordinates for Girton Recreation Ground
    const map = L.map('map').setView(mapCoords, 15);

    // Using a custom tile layer from CARTO for a more minimalist style
    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
        subdomains: 'abcd',
        maxZoom: 20
    }).addTo(map);

    L.marker(mapCoords).addTo(map)
        .bindPopup('<b>Girton Feast</b><br>Girton Recreation Ground').openPopup();
</script>
{% endblock %}
