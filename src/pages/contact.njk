---
layout: layouts/base.njk
title: Contact Us - Girton Feast
bodyClass: ""
permalink: /pages/contact.html
eleventyNavigation:
  key: Contact Us
  order: 1
---

{% from "components/sticker-button.njk" import stickerButton %}

<main class="contact-page position-relative overflow-hidden">
    <!-- Rotated Background Layers -->
    <div class="contact-bg-pink"></div>
    <div class="contact-bg-yellow"></div>
    <div class="contact-bg-green"></div>

    <div class="container position-relative py-5" style="z-index: 10;">

        <!-- Page Heading -->
        <div class="text-center pt-4 mb-5">
            <h1 class="contact-page-title">Get In Touch</h1>
            <p class="contact-page-subtitle">We'd love to hear from you — whether you have questions,<br class="d-none d-md-inline"> want to get involved, or need event information.</p>
        </div>

        <!-- Contact Card Wrapper -->
        <div class="contact-card-wrapper mb-5">
            <!-- Decorative rotated cards behind -->
            <div class="contact-card-bg contact-card-bg-pink"></div>
            <div class="contact-card-bg contact-card-bg-yellow"></div>

            <!-- Main white card -->
            <div class="contact-main-card shadow-lg p-5">
                <div class="row g-5 justify-content-center">

                    <!-- Carol Noble -->
                    <div class="col-lg-5 col-md-6">
                        <div class="contact-person-card">
                            <div class="contact-person-icon" style="background-color: #C8FFE0;">
                                <i class="fas fa-store" style="color: var(--brand-marian-blue);"></i>
                            </div>
                            <h3 class="contact-person-name">Carol</h3>
                            <p class="contact-person-role">Advertising &amp; stall-spacing</p>

                            <ul class="contact-topics-list">
                                <li>Booking a stall</li>
                                <li>Advertising</li>
                            </ul>

                            <hr class="contact-divider">

                            <div class="contact-detail-row">
                                <i class="fas fa-envelope" style="color: var(--brand-v2-purple);"></i>
                                <div>
                                    <small class="contact-detail-label">Email</small>
                                    <a href="#" data-email-user="carol" data-email-domain="girtonfeast.org.uk"
                                       class="contact-email-link fw-bold"></a>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Divider on large screens -->
                    <div class="col-auto d-none d-lg-flex align-items-stretch">
                        <div style="width: 1px; background: rgba(0,0,0,0.08);"></div>
                    </div>

                    <!-- Rowena Barnes -->
                    <div class="col-lg-5 col-md-6">
                        <div class="contact-person-card">
                            <div class="contact-person-icon" style="background-color: #EABEFF;">
                                <i class="fas fa-hands-helping" style="color: var(--brand-marian-blue);"></i>
                            </div>
                            <h3 class="contact-person-name">Rowena</h3>
                            <p class="contact-person-role">Sponsorship, Event Management &amp; General Inquiries</p>

                            <ul class="contact-topics-list">
                                <li>Sponsorship</li>
                                <li>Event Management</li>
                                <li>General inquiries</li>
                            </ul>

                            <hr class="contact-divider">

                            <div class="contact-detail-row">
                                <i class="fas fa-envelope" style="color: var(--brand-thulian-pink);"></i>
                                <div>
                                    <small class="contact-detail-label">Email</small>
                                    <a href="#" data-email-user="rowena" data-email-domain="girtonfeast.org.uk"
                                       class="contact-email-link fw-bold"></a>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Website Feedback & Social Row -->
        <div class="row g-4 mb-5">

            <!-- Website Issues -->
            <div class="col-lg-7">
                <div class="contact-secondary-card shadow-sm p-5">
                    <div class="contact-person-icon mb-4" style="background-color: var(--brand-light-yellow); margin: 0 0 1rem 0;">
                        <i class="fas fa-bug" style="color: var(--brand-marian-blue);"></i>
                    </div>
                    <h3 class="contact-person-name">Website Issues</h3>
                    <p class="contact-person-role mb-4">Spot a bug or have a suggestion? Let us know!</p>

                    <form id="website-feedback-form" onsubmit="event.preventDefault(); sendFeedbackEmail();">
                        <div class="mb-3">
                            <label for="issueType" class="contact-form-label">Issue Type</label>
                            <select class="contact-form-select" id="issueType" required>
                                <option value="" selected disabled>Select an issue type…</option>
                                <option value="Broken Link">Broken Link</option>
                                <option value="Typo/Content Error">Typo or Content Error</option>
                                <option value="Display Issue">Display Issue (Layout/Images)</option>
                                <option value="Suggestion">Feature Suggestion</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="mb-4">
                            <label for="issueDescription" class="contact-form-label">Description</label>
                            <textarea class="contact-form-textarea" id="issueDescription" rows="4"
                                placeholder="Please describe the issue or suggestion…" required></textarea>
                        </div>
                        <div>
                            {{ stickerButton("Send Feedback →", "#", "contact-submit-btn") }}
                        </div>
                    </form>
                </div>
            </div>

            <!-- Social / Follow Us -->
            <div class="col-lg-5">
                <div class="contact-secondary-card shadow-sm p-5 text-center h-100 d-flex flex-column justify-content-center">
                    <h3 class="contact-person-name mb-2">Follow Along</h3>
                    <p class="contact-person-role mb-4">Stay updated with the latest news and announcements!</p>

                    <div class="d-flex gap-3 justify-content-center mb-4">
                        <a href="https://www.facebook.com/GirtonFeastWeek"
                           class="footer-v2-social-icon"
                           aria-label="Facebook" target="_blank">
                            <i class="fab fa-facebook-f"></i>
                        </a>
                        <a href="https://youtu.be/0FqhvdgCn3E?si=2SnO4hMgtZKrgjjJ"
                           class="footer-v2-social-icon"
                           aria-label="YouTube" target="_blank">
                            <i class="fab fa-youtube"></i>
                        </a>
                        <a href="https://nextdoor.co.uk/search/?view=detail&init_source=search&query=%23girtonfeast&ccid=93bf984a-9a4c-401f-a5f8-c9bdcf0ba673&navigationScreen=POST&ssid=9fddbc32-dc0e-4d66-b684-c5e393c3f17a"
                           class="footer-v2-social-icon"
                           aria-label="Nextdoor" target="_blank">
                            <img src="{{ "/images/nextdoor-icon.svg" | url }}" alt="Nextdoor"
                                 style="width: 1em; height: 1em; filter: brightness(0) invert(1);">
                        </a>
                    </div>

                    <p class="footer-v2-hashtag">#GirtonFeast</p>
                </div>
            </div>

        </div>
    </div>
</main>

{% block extra_scripts %}
<script>
    // Reveal obfuscated email addresses
    document.querySelectorAll('a[data-email-user][data-email-domain]').forEach(function(el) {
        const email = el.getAttribute('data-email-user') + '@' + el.getAttribute('data-email-domain');
        el.textContent = email;
        el.href = 'mailto:' + email;
    });

    // Website feedback form — opens mailto
    function sendFeedbackEmail() {
        const user = 'andrew.michael.mcloughlin+girtonfeast';
        const domain = 'gmail.com';
        const email = user + '@' + domain;

        const issueType = document.getElementById('issueType').value;
        const description = document.getElementById('issueDescription').value;

        const subject = encodeURIComponent('Website Feedback: ' + issueType);
        const body = encodeURIComponent('Issue Type: ' + issueType + '\n\nDescription:\n' + description + '\n\nSent from: ' + window.location.href);

        window.location.href = 'mailto:' + email + '?subject=' + subject + '&body=' + body;
    }

    // Wire up the sticker button in the feedback form to submit the form
    document.querySelector('.contact-submit-btn')?.addEventListener('click', function(e) {
        e.preventDefault();
        document.getElementById('website-feedback-form').requestSubmit();
    });
</script>
{% endblock %}
