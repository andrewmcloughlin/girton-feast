---
layout: layouts/base.njk
title: Photo Gallery - Girton Feast
bodyClass: bg-white
permalink: /pages/gallery.html
eleventyNavigation:
  key: Photo Gallery
  order: 5
  icon: fas fa-images
---

{% block extra_head %}
<!-- Fancybox CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />
{% endblock %}

<div class="bg-white min-vh-100 py-5">
    <div class="container pt-5">
        <div class="text-center mb-5 animate-on-scroll">
            <h1 class="get-involved-title mt-4">Relive the memories</h1>
            <p class="lead text-muted font-comfortaa">A look back at previous years of the Girton Feast.</p>
        </div>

        <div class="row position-relative">
            <!-- Sticky Navigation Column -->
            <div class="col-lg-3 mb-4">
                <div class="gallery-nav-container sticky-top" style="top: 100px; z-index: 1020;">
                    <h4 class="font-dynapuff mb-3 text-brand-purple">Select Year</h4>

                    <!-- Desktop Nav -->
                    <nav id="gallery-nav" class="p-3 rounded-4 bg-white d-none d-lg-block">
                        <ul id="gallery-nav-ul" class="nav nav-pills flex-column gap-2">
                            <!-- Year links will be dynamically inserted here -->
                        </ul>
                    </nav>

                    <!-- Mobile Dropdown -->
                    <div class="d-lg-none">
                        <div class="dropdown">
                            <button class="sticker-button sticker-button-pink w-100 dropdown-toggle" type="button" id="galleryDropdown"
                                data-bs-toggle="dropdown" aria-expanded="false">
                                Select a Year
                            </button>
                            <ul id="gallery-dropdown-ul" class="dropdown-menu w-100 border-thick shadow" aria-labelledby="galleryDropdown">
                                <!-- Mobile year links will be inserted here -->
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Gallery Content Column -->
            <div id="gallery-container-wrapper" class="col-lg-9">
                <div id="gallery-container">
                    <!-- Loading State -->
                    <div class="text-center py-5">
                        <div class="spinner-border text-brand-purple" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% block extra_scripts %}
<!-- JSZip library for creating zip files -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<!-- Fancybox JS -->
<script src="https://cdn.jsdelivr.net/npm/@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>
<script>
    // --- START: Gallery Configuration ---
    const photoConfig = [
        { year: 2025, imageCount: 52 },
        { year: 2018, imageCount: 36 },
        { year: 2017, imageCount: 40 },
        { year: 2016, imageCount: 45 },
        { year: 2015, imageCount: 15 },
        { year: 2014, imageCount: 14 },
        { year: 2013, imageCount: 41 },
        { year: 2012, imageCount: 50 },
    ];
    // --- END: Gallery Configuration ---

    let currentYear = photoConfig[0].year;

    function buildNavigation() {
        const desktopNav = document.getElementById('gallery-nav-ul');
        const mobileNav = document.getElementById('gallery-dropdown-ul');
        const mobileBtn = document.getElementById('galleryDropdown');

        let desktopHtml = '';
        let mobileHtml = '';

        photoConfig.sort((a,b) => b.year - a.year).forEach(config => {
            const activeClass = config.year === currentYear ? 'active' : '';
            desktopHtml += `
                <li class="nav-item">
                    <a class="nav-link font-dynapuff text-center py-2 px-3 border-thick rounded-pill mb-2 ${activeClass}"
                       href="javascript:void(0)" onclick="switchYear(${config.year})">${config.year}</a>
                </li>
            `;
            mobileHtml += `
                <li><a class="dropdown-item font-dynapuff py-2 ${activeClass}" href="javascript:void(0)" onclick="switchYear(${config.year})">${config.year}</a></li>
            `;
        });

        desktopNav.innerHTML = desktopHtml;
        mobileNav.innerHTML = mobileHtml;
        mobileBtn.textContent = `Year: ${currentYear}`;
    }

    function switchYear(year) {
        if (year === currentYear) return;
        currentYear = year;
        buildNavigation();
        renderGallery();
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function renderGallery() {
        const container = document.getElementById('gallery-container');
        const config = photoConfig.find(c => c.year === currentYear);
        if (!config) return;

        let html = `
            <div class="fadeIn">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-5 gap-3">
                    <h2 class="display-4 font-glass-antiqua text-brand-purple mb-0">${config.year} Collection</h2>
                    <button class="sticker-button sticker-button-pink" onclick="downloadYearAsZip(${config.year}, this)">
                        <i class="fas fa-download me-2"></i>Download All
                    </button>
                </div>
                <div class="polaroid-gallery">
        `;

        const prefix = window.siteConfig?.pathPrefix || '/';
        const cleanPrefix = prefix.endsWith('/') ? prefix : prefix + '/';

        for (let i = 1; i <= config.imageCount; i++) {
            const imagePath = `${cleanPrefix}images/previous/${config.year}/${i}.jpg`;

            // Random rotation between -3 and 3 degrees
            const rotation = (Math.random() * 6 - 3).toFixed(2);
            const delay = (i % 20) * 40; // Stagger first 20 images

            html += `
                <a href="${imagePath}"
                   data-fancybox="gallery-${config.year}"
                   data-caption="Girton Feast ${config.year} - Photo ${i}"
                   class="polaroid-item fadeInUp"
                   style="transform: rotate(${rotation}deg); animation-delay: ${delay}ms;">
                    <img src="${imagePath}" alt="Photo ${i}" loading="lazy" onload="this.classList.add('loaded')">
                </a>
            `;
        }

        html += `</div></div>`;
        container.innerHTML = html;

        // Re-bind Fancybox
        Fancybox.bind("[data-fancybox]", {});
    }

    async function downloadYearAsZip(year, button) {
        const config = photoConfig.find(c => c.year === year);
        if (!config) return;

        const originalText = button.innerHTML;
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Zipping...';

        const zip = new JSZip();
        const imagePromises = [];

        for (let i = 1; i <= config.imageCount; i++) {
            const prefix = window.siteConfig?.pathPrefix || '/';
            const imageUrl = `${prefix}images/previous/${year}/${i}.jpg`;
            const promise = fetch(imageUrl)
                .then(response => {
                    if (!response.ok) throw new Error(`Image ${i}.jpg not found`);
                    return response.blob();
                })
                .then(blob => {
                    zip.file(`${i}.jpg`, blob);
                })
                .catch(error => console.error(`Failed to fetch ${imageUrl}:`, error));
            imagePromises.push(promise);
        }

        await Promise.all(imagePromises);

        zip.generateAsync({ type: "blob" })
            .then(function (content) {
                const link = document.createElement('a');
                link.href = URL.createObjectURL(content);
                link.download = `girton-feast-${year}-photos.zip`;
                document.body.appendChild(link);
                link.click();
                document.body.removeChild(link);

                button.disabled = false;
                button.innerHTML = originalText;
            });
    }

    document.addEventListener('DOMContentLoaded', () => {
        buildNavigation();
        renderGallery();
    });
</script>
{% endblock %}
